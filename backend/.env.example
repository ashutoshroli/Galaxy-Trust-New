PORT=3000

# Set to "production" on your live server for JSON logs + hidden error stacks
NODE_ENV=development

# --- Database ---
# Local (Termux): use individual settings below.
DB_USER=dbadmin
DB_PASSWORD=changeme
DB_NAME=galaxy_trust_db
DB_HOST=localhost
DB_PORT=5432

# Cloud (Neon/Render/Supabase): set a single connection string + SSL instead.
# When DATABASE_URL is set, the DB_* values above are ignored.
# DATABASE_URL=postgresql://user:pass@host/dbname
# DB_SSL=true

# db/schema.sql is applied automatically on every server startup (it's fully
# idempotent, so this is safe to leave on). Set to "true" to disable and
# manage migrations manually with `npm run setup-db` instead.
SKIP_AUTO_MIGRATE=false

# --- Auth ---
# IMPORTANT: change this to a long random string (32+ chars) before going live.
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=8h
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME_MINUTES=15

# --- Password reset (email) ---
# Base URL of the deployed frontend — used to build the reset link in emails.
# e.g. https://galaxy-trust-new.vercel.app  (falls back to the first CORS_ORIGIN if unset)
FRONTEND_URL=
# How long a reset link stays valid (minutes)
RESET_TOKEN_TTL_MIN=30

# --- Email delivery (password reset) ---
# Pick ONE provider. On Render's free tier, SMTP ports (25/465/587) are BLOCKED,
# so use an HTTP API provider (Brevo or Resend) instead.
#
# Option A (recommended on Render) — Brevo HTTP API: https://www.brevo.com
#   1. Verify a sender email (Senders & Domains), 2. create an API key.
BREVO_API_KEY=
#
# Option B — Resend HTTP API: https://resend.com
RESEND_API_KEY=
#
# Option C — SMTP (works locally / on paid hosts that allow SMTP):
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
#
# Sender shown to recipients (use a verified address). Defaults to SMTP_USER.
MAIL_FROM=Galaxy Trust <no-reply@example.com>

# --- WhatsApp / SMS reminders (Twilio) ---
# Optional. If unset, reminders are still sent as in-app/push notifications;
# WhatsApp/SMS delivery is simply skipped (logged, not an error).
# Sign up at https://www.twilio.com (has a free trial with test credits).
#   1. Get your Account SID + Auth Token from the Twilio Console dashboard.
#   2. For SMS: buy/use a Twilio phone number -> TWILIO_SMS_FROM (e.g. +15551234567)
#   3. For WhatsApp: use Twilio's WhatsApp sandbox number while testing, or
#      your own approved WhatsApp sender in production ->
#      TWILIO_WHATSAPP_FROM (format: whatsapp:+14155238886)
# If both are set, WhatsApp is tried first and SMS is the fallback.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=

# --- Scheduled reminders (cron) ---
# Runs automatically every day: nudges members with a pending installment
# balance, and wishes members a happy birthday. No admin action needed.
# Disable entirely:
ENABLE_REMINDERS=true
# When it runs (cron syntax, server time). Default: 9:00 AM daily.
REMINDER_CRON=0 9 * * *
# Minimum days between repeat installment reminders to the same member.
REMINDER_COOLDOWN_DAYS=3

# --- CORS ---
# Comma-separated list of allowed frontend origins, e.g.
# CORS_ORIGIN=https://galaxy.example.com,http://localhost:5174
# Leave empty to allow all origins (handy for local/self-hosted setups).
CORS_ORIGIN=

# --- Cloudinary (OPTIONAL — for hosting feed images instead of base64 in DB) ---
# Sign up at https://cloudinary.com (free). Leave empty to store images as base64.
# Easiest: paste the single connection URL from your Cloudinary dashboard:
CLOUDINARY_URL=
# OR set them individually instead of the URL above:
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
